# ─────────────────────────────────────────────────────────────────
# ChefAI Vision — Backend Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────────

# ── REQUIRED: OpenAI API Key ─────────────────────────────────────
# Powers the AI vision analysis (camera coaching feature)
# Get one at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Which OpenAI model to use for vision (gpt-4o-mini is cheapest)
OPENAI_MODEL=gpt-4o-mini

# ── OPTIONAL: ElevenLabs API Key ─────────────────────────────────
# Powers realistic voice TTS (Chef Marcus, Chef Sofia, Chef James)
# If not set, the app falls back to browser's built-in speech synthesis
# Get one at: https://elevenlabs.io
ELEVENLABS_API_KEY=

# ── Server settings ──────────────────────────────────────────────
PORT=3001

# Allow requests from the frontend dev server (and any origin for APK)
FRONTEND_ORIGIN=http://localhost:5173

# ── Auth secret ──────────────────────────────────────────────────
# Used to sign JWT login tokens — change this to any long random string
JWT_SECRET=change-this-to-a-long-random-secret-string
