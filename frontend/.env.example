# ChefAI Vision — Frontend Environment Variables
# Copy this file to .env and fill in your values
# For APK builds: this IP must be reachable from your Android phone

# Your backend server address
# - Local development (browser): http://localhost:3001
# - APK on phone (same WiFi): http://192.168.1.XXX:3001  (find IP: ipconfig/ifconfig)
# - Deployed to cloud: https://your-backend.railway.app
VITE_API_BASE_URL=http://localhost:3001
