# Dependencies — never commit these
node_modules/
frontend/node_modules/
backend/node_modules/

# Frontend build — Railway builds this fresh inside Docker
frontend/dist/

# Environment files — NEVER commit real secrets
backend/.env
.env

# Database — reset on each deploy (Railway ephemeral filesystem)
backend/data/
data/

# OS / editor noise
.DS_Store
Thumbs.db
.vscode/
*.log
npm-debug.log*
